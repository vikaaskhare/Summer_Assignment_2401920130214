class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        vector<int>ans;
        int n=nums.size();
        for(int i=0;i<n;i++)
        {
           if(i==n-1)
           {
            if(nums[i]!=nums[i-1])
           ans.push_back(nums[i]);
           }
           else
           {
            if(nums[i]!=nums[i+1])
           ans.push_back(nums[i]);
           }

        }
        return ans.size();
    }
};
